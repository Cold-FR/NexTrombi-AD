{
    "name": "nextrombi-ad/nextrombi-ad-server",
    "description": "Trombinoscope visuel connecté à Active Directory — API Symfony, authentification LDAP/JWT, gestion des photos.",
    "keywords": [
        "trombinoscope",
        "active-directory",
        "ldap",
        "symfony",
        "jwt"
    ],
    "homepage": "https://github.com/Cold-FR/NexTrombi-AD",
    "license": "MIT",
    "authors": [
        {
            "name": "NexTrombi-AD Contributors",
            "homepage": "https://github.com/Cold-FR/NexTrombi-AD/graphs/contributors"
        }
    ],
    "version": "1.0.0",
    "type": "project",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "directorytree/ldaprecord": "^4.0.2",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.2",
        "lexik/jwt-authentication-bundle": "^3.2",
        "nelmio/cors-bundle": "^2.6.1",
        "symfony/console": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^4.0.1",
        "symfony/runtime": "8.0.*",
        "symfony/uid": "8.0.*",
        "symfony/yaml": "8.0.*",
        "ext-exif": "*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpro/grumphp": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "symfony serve"
        ],
        "test:csfixer": [
            "php-cs-fixer fix --dry-run"
        ],
        "fix:csfixer": [
            "php-cs-fixer fix"
        ],
        "test:phpstan": [
            "php -d memory_limit=512M vendor/bin/phpstan analyse"
        ],
        "test:yaml": [
            "php bin/console lint:yaml config"
        ],
        "test:phpunit": [
            "php bin/console doctrine:schema:drop --force --env=test",
            "php bin/console doctrine:schema:create --env=test",
            "php bin/phpunit --colors=always --display-phpunit-notices --display-phpunit-deprecations"
        ],
        "test:phpunit:coverage": [
            "php bin/console doctrine:schema:drop --force --env=test",
            "php bin/console doctrine:schema:create --env=test",
            "php bin/phpunit --colors=always --display-phpunit-notices --display-phpunit-deprecations --coverage-html=coverage/"
        ],
        "test": [
            "@test:csfixer",
            "@test:phpstan",
            "@test:yaml",
            "@test:phpunit"
        ],
        "fix": [
            "@fix:csfixer"
        ],
        "db": [
            "php bin/console doctrine:database:drop --force --if-exists",
            "php bin/console doctrine:database:create --if-not-exists",
            "php bin/console doctrine:migrations:migrate --no-interaction"
        ]
    },
    "scripts-descriptions": {
        "fix:csfixer": "Corrige le code PHP avec PHP CS Fixer",
        "test:csfixer": "Teste le code PHP avec PHP CS Fixer",
        "test:phpstan": "Teste le code PHP avec PhpStan",
        "test:phpunit": "Teste le code PHP avec PHPUnit",
        "test:phpunit:coverage": "Teste le code PHP avec PHPUnit et génère un rapport de couverture de code",
        "test:yaml": "Vérifie les fichiers dans le répertoire config",
        "test": "Lance tous les tests",
        "fix": "Lance tous les scripts de correction",
        "db": "Supprime, crée, et migre la base de données",
        "start": "Démarre le serveur"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "phpro/grumphp": "^2.19",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.42",
        "phpstan/phpstan-doctrine": "^2.0.20",
        "phpstan/phpstan-symfony": "^2.0.15",
        "phpunit/phpunit": "^13.0.5",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/maker-bundle": "^1.67"
    }
}
